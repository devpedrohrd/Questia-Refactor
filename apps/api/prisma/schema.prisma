generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =========================
// ENUMS
// =========================

enum Role {
  PROFESSOR
  ALUNO
  ADMIN
}

enum Difficulty {
  FACIL
  MEDIO
  DIFICIL
}

enum QuestionType {
  MULTIPLA_ESCOLHA
  VERDADEIRO_FALSO
  DISCURSIVA
}

enum QuizStatus {
  DRAFT
  GENERATED
  PUBLISHED
  ARCHIVED
}

enum CognitiveLevel {
  LEMBRAR
  COMPREENDER
  APLICAR
  ANALISAR
  AVALIAR
  CRIAR
}

enum LanguageStyle {
  SIMPLES
  FORMAL
  TECNICO
  INFANTIL
  VESTIBULAR
  ENEM
}

enum DifficultyStrategy {
  UNIFORME
  PROGRESSIVA
  PERSONALIZADA
}

// =========================
// USER
// =========================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  role      Role     @default(ALUNO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizzes             Quiz[]
  attempts            Attempt[]
  generationContexts  GenerationContext[]
}

// =========================
// GENERATION CONTEXT
// =========================

model GenerationContext {
  id String @id @default(uuid())

  name String

  gradeLevel String
  subject String
  topic String

  learningObjectives String[]

  cognitiveLevel CognitiveLevel
  languageStyle LanguageStyle
  difficultyStrategy DifficultyStrategy

  rules String[]

  referenceMaterial String?

  examples Json?

  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  quizzes Quiz[]

  @@index([userId])
}

// =========================
// QUIZ
// =========================

model Quiz {
  id String @id @default(uuid())

  title String
  theme String

  difficulty Difficulty
  questionType QuestionType

  questionCount Int

  accessLink String @unique

  status QuizStatus @default(DRAFT)

  userId String
  generationContextId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  generationContext GenerationContext?  @relation(fields: [generationContextId], references: [id])

  questions Question[]
  attempts Attempt[]

  @@index([userId])
  @@index([generationContextId])
}

// =========================
// QUESTION
// =========================

model Question {
  id String @id @default(uuid())

  statement String

  type QuestionType

  explanation String?

  correctAnswer String?

  quizId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  alternatives Alternative[]
  answers Answer[]

  @@index([quizId])
}

// =========================
// ALTERNATIVE
// =========================

model Alternative {
  id String @id @default(uuid())

  text String

  isCorrect Boolean @default(false)

  questionId String

  createdAt DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

// =========================
// ATTEMPT
// =========================

model Attempt {
  id String @id @default(uuid())

  score Int
  totalQuestions Int

  percentage Float

  userId String
  quizId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  answers Answer[]

  @@index([userId])
  @@index([quizId])
}

// =========================
// ANSWER
// =========================

model Answer {
  id String @id @default(uuid())

  response String

  isCorrect Boolean

  questionId String
  attemptId String

  createdAt DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([attemptId])
}